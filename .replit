modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_log_in_with_replit:2.0.0", "javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[userenv]

[userenv.shared]
API_PORT = "3000"
DODO_STARTER_MONTHLY_ID = "pdt_0NbFfMOQIsJF9X0LrtkH9"
DODO_STARTER_ANNUAL_ID = "pdt_0NbC7p1x3vArb3CYIqAT6"
DODO_GROWTH_MONTHLY_ID = "pdt_0NbC3RvgjyFoZ6wJ7LLqP"
DODO_GROWTH_ANNUAL_ID = "pdt_0NbC5NQsoxq2leqmoeDmB"
DODO_SCALE_MONTHLY_ID = "pdt_0NcBuLfSXkF4hSJFs0AbV"
DODO_SCALE_ANNUAL_ID = "pdt_0NbFhELrTC3P4kNf8On24"
DODO_API_BASE = "https://api.dodopayments.com"
NODE_ENV = "development"
